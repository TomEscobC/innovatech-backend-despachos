# ─────────────────────────────────────────────────────────────────
# .env.example — Variables de entorno para Backend Despachos
# COPIAR a .env y completar con valores reales (NO commitear .env)
# ─────────────────────────────────────────────────────────────────

# Base de datos
DB_NAME=despachos_db
DB_USERNAME=app_user
DB_PASSWORD=cambia_esto_por_password_seguro
MYSQL_ROOT_PASSWORD=cambia_esto_por_root_password

# Puerto del backend (usado en EC2 / docker run)
SERVER_PORT=8081
